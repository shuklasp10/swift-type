<file path=".github/workflows/release.yaml">
name: Release

on:
  push:
    tags:
      - 'v*'

# Workflow-level permissions — required for GITHUB_TOKEN to create releases.
# Also verify Settings → Actions → General → Workflow permissions is "Read and write".
permissions:
  contents: write

# Prevent duplicate releases if tags are pushed in quick succession
concurrency:
  group: release-${{ github.ref }}
  cancel-in-progress: true

jobs:
  publish-tauri:
    runs-on: windows-latest

    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install Rust stable
        uses: dtolnay/rust-toolchain@stable

      - name: Install frontend dependencies
        run: npm ci

      # Determine bundle targets and release flags from the tag.
      # MSI (WiX) only supports X.Y.Z versions — pre-release tags like
      # "alpha.0" are invalid. Skip MSI for pre-release builds.
      - name: Determine release parameters
        id: params
        shell: pwsh
        run: |
          $tag = "${{ github.ref_name }}" -replace '^v', ''
          if ($tag -match '-') {
            # Pre-release tag (e.g. 1.4.2-alpha.0) — NSIS only, mark as prerelease
            "bundles=nsis" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
            "prerelease=true" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
          } else {
            # Stable tag (e.g. 1.4.2) — both NSIS and MSI
            "bundles=nsis,msi" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
            "prerelease=false" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
          }

      - name: Extract changelog for this version
        id: changelog
        shell: pwsh
        run: |
          $tag = "${{ github.ref_name }}" -replace '^v', ''
          $body = "See the assets below to download and install this version."
          if (Test-Path CHANGELOG.md) {
            $content = Get-Content CHANGELOG.md -Raw
            if ($content -match "(?ms)## \[$tag\].*?\n(.*?)(?=\n## \[|$)") {
              $extracted = $Matches[1].Trim()
              if ($extracted) { $body = $extracted }
            }
          }
          "body<<CHANGELOG_EOF" | Out-File -FilePath $env:GITHUB_OUTPUT -Append
          $body | Out-File -FilePath $env:GITHUB_OUTPUT -Append
          "CHANGELOG_EOF" | Out-File -FilePath $env:GITHUB_OUTPUT -Append

      # tauri-action runs `beforeBuildCommand` (npm run build) internally before
      # invoking cargo. No need to build separately — that just doubles the time.
      - name: Build and release Tauri app
        uses: tauri-apps/tauri-action@v0.5
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          TAURI_SIGNING_PRIVATE_KEY: ${{ secrets.TAURI_SIGNING_PRIVATE_KEY }}
          TAURI_SIGNING_PRIVATE_KEY_PASSWORD: ${{ secrets.TAURI_SIGNING_PRIVATE_KEY_PASSWORD }}
        with:
          tagName: ${{ github.ref_name }}
          releaseName: SwiftType ${{ github.ref_name }}
          releaseBody: |
            ## What's New in ${{ github.ref_name }}

            ${{ steps.changelog.outputs.body }}

            ### Installation
            - **EXE installer (recommended):** Download the `_x64-setup.exe` file
            - **MSI installer:** Download the `_x64_en-US.msi` file
          releaseDraft: false
          prerelease: ${{ steps.params.outputs.prerelease == 'true' }}
          tauriScript: npx tauri
          args: --bundles ${{ steps.params.outputs.bundles }}

      # If the release step fails after build succeeds, preserve artifacts
      - name: Upload build artifacts (fallback)
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: release-artifacts-${{ github.ref_name }}
          path: |
            src-tauri/target/release/bundle/msi/*.msi
            src-tauri/target/release/bundle/nsis/*-setup.exe
          retention-days: 7
</file>

