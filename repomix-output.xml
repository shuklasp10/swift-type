<file path="src/types.ts">
export interface Snippet {
  id: string;
  trigger: string | null;
  regex: string | null;
  replace: string;
  label: string | null;
  word: boolean;
  uppercase_style: string | null;
  image_path: string | null;
  shell: string | null;
  form_fields: FormField[] | null;
